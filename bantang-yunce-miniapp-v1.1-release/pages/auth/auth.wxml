<view class="page">
  <view class="shell">
    <brand-header subtitle="请登录使用" compact="{{true}}" auth="{{auth}}" loginUrl="/pages/auth/auth"></brand-header>

    <view class="section card hero-card">
      <view class="section-head">
        <view>
          <text class="section-title">注册 / 登录</text>
          <text class="section-subtitle">微信账号或手机号都可以。未登录时，只能浏览页面内容。</text>
        </view>
      </view>
      <view class="mode-tabs">
        <view class="mode-tab {{mode === 'wechat' ? 'active' : ''}}" data-mode="wechat" bindtap="switchMode">微信账号</view>
        <view class="mode-tab {{mode === 'phone' ? 'active' : ''}}" data-mode="phone" bindtap="switchMode">手机号</view>
      </view>
    </view>

    <view wx:if="{{mode === 'wechat'}}" class="section card form-card">
      <view class="section-title">微信账号登录</view>
      <view class="section-subtitle">输入昵称，头像可选；不填头像时会显示默认简化图。</view>
      <view class="field-block">
        <text class="field-label">昵称</text>
        <input class="input" placeholder="例如：妈妈小糖" value="{{wechatName}}" bindinput="onWechatNameInput"></input>
      </view>
      <view class="field-block">
        <text class="field-label">头像（可选）</text>
        <view class="avatar-picker" bindtap="chooseAvatar">
          <image wx:if="{{wechatAvatar}}" class="avatar-preview" src="{{wechatAvatar}}" mode="aspectFill"></image>
          <text wx:else class="avatar-plus">+</text>
        </view>
      </view>
      <view class="consent-row">
        <switch checked="{{agreePrivacy}}" disabled="{{!hasReadPrivacy}}" bindchange="toggleAgree"></switch>
        <view class="consent-copy">
          <view class="consent-line">
            <text class="consent-title">我已阅读并同意</text>
            <text class="privacy-link" catchtap="openPrivacy">隐私协议</text>
          </view>
          <text class="consent-desc">{{hasReadPrivacy ? '已阅读，可勾选后登录。' : '请先点击隐私协议阅读全文，再勾选。'}}</text>
        </view>
      </view>
      <view class="btn btn-primary action-btn" bindtap="loginWithWechat">微信登录</view>
    </view>

    <view wx:else class="section card form-card">
      <view class="section-title">手机号登录</view>
      <view class="section-subtitle">输入手机号和验证码完成登录；手机号仅用于本地账号标识。</view>
      <view class="field-block">
        <text class="field-label">手机号</text>
        <view class="phone-row">
          <input class="input phone-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{phoneNumber}}" bindinput="onPhoneInput"></input>
          <view class="send-code-btn" bindtap="sendSmsCode">{{codeSent ? '已发送' : '发送验证码'}}</view>
        </view>
      </view>
      <view class="field-block">
        <text class="field-label">验证码</text>
        <input class="input" type="number" maxlength="6" placeholder="请输入验证码" value="{{smsCode}}" bindinput="onCodeInput"></input>
      </view>
      <view class="consent-row">
        <switch checked="{{agreePrivacy}}" disabled="{{!hasReadPrivacy}}" bindchange="toggleAgree"></switch>
        <view class="consent-copy">
          <view class="consent-line">
            <text class="consent-title">我已阅读并同意</text>
            <text class="privacy-link" catchtap="openPrivacy">隐私协议</text>
          </view>
          <text class="consent-desc">{{hasReadPrivacy ? '已阅读，可勾选后登录。' : '请先点击隐私协议阅读全文，再勾选。'}}</text>
        </view>
      </view>
      <view class="btn btn-primary action-btn" bindtap="loginWithPhone">手机号登录</view>
    </view>
  </view>
</view>
