.feedback-form, .record-card { padding: 22rpx; margin-top: 24rpx; }
.form-block + .form-block { margin-top: 22rpx; }
.radio-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14rpx; margin-top: 14rpx; }
.radio-item { display: flex; align-items: center; gap: 10rpx; min-height: 72rpx; padding: 0 18rpx; border-radius: 22rpx; background: #fffaf1; border: 1rpx solid rgba(223, 214, 197, 0.88); }
.picker-value { display: flex; align-items: center; min-height: 76rpx; }
.field-hint { display: block; margin-top: 10rpx; color: #637169; font-size: 22rpx; line-height: 1.45; }
.image-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12rpx; margin-top: 14rpx; }
.image-tile, .image-add { position: relative; overflow: hidden; border-radius: 22rpx; aspect-ratio: 1; background: #f4eadb; }
.image-preview { width: 100%; height: 100%; }
.image-add { display: flex; align-items: center; justify-content: center; color: #415f4b; font-size: 48rpx; font-weight: 700; }
.submit-btn { margin-top: 22rpx; }
.record-list { display: grid; gap: 14rpx; margin-top: 18rpx; }
.record-row { padding: 18rpx; border-radius: 22rpx; background: #fffaf1; border: 1rpx solid rgba(223, 214, 197, 0.88); }
.record-row.highlighted { border-color: #c97766; box-shadow: 0 12rpx 24rpx rgba(201, 119, 102, 0.12); }
.record-top { display: flex; align-items: center; justify-content: space-between; gap: 14rpx; }
.record-id { color: #8a7565; font-size: 20rpx; line-height: 1.35; }
.record-status { color: #c97766; font-size: 22rpx; font-weight: 800; line-height: 1.35; }
.record-content { display: block; margin-top: 10rpx; color: #24302c; font-size: 24rpx; line-height: 1.55; }
