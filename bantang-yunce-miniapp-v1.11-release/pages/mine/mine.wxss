.profile-card, .summary-card, .tools-card, .settings-card, .feedback-card { padding: 22rpx; margin-top: 24rpx; }
.profile-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18rpx; margin-top: 18rpx; }
.picker-value { display: flex; align-items: center; min-height: 76rpx; }
.picker-value.readonly { color: #9da8a0; }
.stage-mini-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14rpx; margin-top: 18rpx; }
.setting-list { display: grid; gap: 12rpx; margin-top: 18rpx; margin-bottom: 12rpx; }
.tool-list { display: grid; gap: 12rpx; margin-top: 18rpx; }
.tool-row, .setting-row { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; padding: 18rpx; border-radius: 24rpx; background: #fffaf1; border: 1rpx solid rgba(223, 214, 197, 0.88); }
.tool-title { display: block; font-size: 28rpx; font-weight: 800; line-height: 1.3; }
.tool-desc { display: block; margin-top: 8rpx; color: #637169; font-size: 22rpx; line-height: 1.5; }
.setting-action { flex: 0 0 auto; color: #c97766; font-size: 24rpx; font-weight: 800; }
.feedback-card { padding-bottom: 28rpx; }
.feedback-btn { margin-top: 18rpx; }
@media (max-width: 720rpx) { .profile-grid, .stage-mini-grid { grid-template-columns: 1fr; } }

.profile-input { min-height: 114rpx; }
