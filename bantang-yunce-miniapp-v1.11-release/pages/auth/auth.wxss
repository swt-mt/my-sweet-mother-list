.hero-card, .form-card { padding: 22rpx; margin-top: 24rpx; }
.field-block { margin-top: 18rpx; }
.avatar-picker { width: 132rpx; height: 132rpx; border-radius: 32rpx; background: #fffaf1; border: 2rpx dashed rgba(120, 146, 125, 0.55); display: flex; align-items: center; justify-content: center; overflow: hidden; }
.avatar-preview { width: 100%; height: 100%; }
.avatar-plus { color: #78927d; font-size: 58rpx; font-weight: 700; line-height: 1; }
.consent-row { display: flex; align-items: flex-start; gap: 14rpx; margin-top: 22rpx; padding: 18rpx; border-radius: 24rpx; background: #fffaf1; border: 1rpx solid rgba(223, 214, 197, 0.88); }
.consent-copy { min-width: 0; flex: 1; }
.consent-line { display: flex; align-items: center; flex-wrap: wrap; gap: 8rpx; }
.consent-title { display: inline; font-size: 26rpx; font-weight: 800; line-height: 1.32; }
.privacy-link { display: inline; color: #415f4b; font-size: 26rpx; font-weight: 800; line-height: 1.32; text-decoration: underline; text-underline-offset: 5rpx; }
.consent-desc { display: block; margin-top: 8rpx; color: #637169; font-size: 22rpx; line-height: 1.5; }
.action-btn { margin-top: 22rpx; width: 100%; }
.auth-input { min-height: 114rpx; }
