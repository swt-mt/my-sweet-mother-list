.site-nav { position: fixed; left: 0; right: 0; bottom: 0; z-index: 999; display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12rpx; width: 100%; max-width: 750rpx; margin: 0 auto; padding: 12rpx 24rpx calc(12rpx + env(safe-area-inset-bottom)); border: 1rpx solid rgba(223, 214, 197, 0.96); border-bottom: 0; border-radius: 28rpx 28rpx 0 0; background: #fffaf1; box-shadow: 0 -12rpx 32rpx rgba(48, 62, 55, 0.08); }
.site-nav__item { display: flex; align-items: center; justify-content: center; min-height: 78rpx; border-radius: 22rpx; color: #637169; background: #f4eadb; font-size: 26rpx; font-weight: 700; }
.site-nav__item.active { color: #fffaf1; background: #415f4b; }
