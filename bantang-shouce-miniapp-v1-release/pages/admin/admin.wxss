.page--admin { padding-bottom: 24rpx; }
.admin-hero { position: relative; padding: 24rpx; margin-top: 0; background: linear-gradient(135deg, rgba(255, 248, 237, 0.98) 0%, rgba(246, 239, 230, 0.96) 48%, rgba(237, 245, 239, 0.96) 100%); }
.admin-hero__copy { margin-top: 18rpx; }
.admin-hero__eyebrow { display: block; color: #8f5147; font-size: 24rpx; font-weight: 800; letter-spacing: 0.08em; }
.admin-hero__lead { display: block; margin-top: 14rpx; color: #4c5a53; font-size: 28rpx; line-height: 1.68; }
.admin-hero__chips { display: flex; flex-wrap: wrap; gap: 10rpx; margin-top: 18rpx; }
.unlock-card, .kpi-card, .trend-card, .feedback-card, .version-card { padding: 24rpx; margin-top: 24rpx; }
.unlock-input, .unlock-btn, .dashboard-kpis, .funnel-list, .feedback-stats, .feedback-group-list { margin-top: 18rpx; }
.dashboard-stat, .feedback-stat { min-height: 142rpx; }
.funnel-row { display: grid; grid-template-columns: 220rpx minmax(0, 1fr) 72rpx; gap: 16rpx; align-items: center; padding: 14rpx 0; }
.funnel-row + .funnel-row { border-top: 1rpx solid rgba(223, 214, 197, 0.6); }
.funnel-label-wrap { display: flex; align-items: center; gap: 12rpx; min-width: 0; }
.funnel-index { display: inline-flex; align-items: center; justify-content: center; flex: 0 0 auto; width: 34rpx; height: 34rpx; border-radius: 12rpx; color: #415f4b; background: rgba(120, 146, 125, 0.12); font-size: 20rpx; font-weight: 800; }
.funnel-label { display: block; min-width: 0; color: #24302c; font-size: 24rpx; font-weight: 700; line-height: 1.3; }
.funnel-track, .group-bar { overflow: hidden; height: 14rpx; border-radius: 999rpx; background: #e8dfcf; }
.funnel-fill { height: 100%; border-radius: inherit; background: linear-gradient(90deg, #78927d, #7bbec1); }
.funnel-value { color: #c97766; font-size: 22rpx; font-weight: 800; text-align: right; }
.feedback-card--wide { width: 100%; }
.feedback-group { padding: 20rpx; border-radius: 26rpx; background: rgba(255, 250, 241, 0.94); border: 1rpx solid rgba(223, 214, 197, 0.88); }
.feedback-group + .feedback-group { margin-top: 16rpx; }
.group-head { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; }
.group-title-wrap { min-width: 0; flex: 1; }
.group-title { display: block; color: #24302c; font-size: 30rpx; font-weight: 800; line-height: 1.28; }
.group-meta { display: block; margin-top: 8rpx; color: #637169; font-size: 22rpx; line-height: 1.45; }
.group-toggle { flex: 0 0 auto; color: #c97766; font-size: 22rpx; font-weight: 800; }
.group-bar { margin-top: 14rpx; }
.group-bar__inner { height: 100%; border-radius: inherit; background: linear-gradient(90deg, #78927d, #7bbec1, #f3d36b); }
.feedback-detail-list { display: grid; gap: 14rpx; margin-top: 16rpx; }
.feedback-empty { padding: 18rpx; border-radius: 20rpx; color: #637169; background: #fffdf8; font-size: 22rpx; }
.feedback-detail { padding: 18rpx; border-radius: 22rpx; background: #fffdf8; border: 1rpx solid rgba(223, 214, 197, 0.84); }
.detail-top { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.detail-user { color: #415f4b; font-size: 24rpx; font-weight: 800; }
.detail-id { color: #8a7565; font-size: 20rpx; line-height: 1.35; }
.detail-question { display: block; margin-top: 12rpx; color: #24302c; font-size: 24rpx; font-weight: 700; line-height: 1.55; text-decoration: underline; text-underline-offset: 5rpx; }
.detail-reply { display: block; margin-top: 10rpx; color: #637169; font-size: 22rpx; line-height: 1.55; }
.reply-row { display: grid; grid-template-columns: minmax(0, 1fr) 150rpx; gap: 12rpx; align-items: stretch; margin-top: 14rpx; }
.reply-input { min-height: 86rpx; padding: 14rpx 16rpx; border-radius: 20rpx; color: #24302c; background: #fffaf1; border: 1rpx solid rgba(223, 214, 197, 0.88); font-size: 22rpx; line-height: 1.5; }
.reply-btn { display: flex; align-items: center; justify-content: center; min-height: 86rpx; border-radius: 20rpx; color: #fffaf1; background: #78927d; font-size: 22rpx; font-weight: 800; }
.version-meta { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16rpx; margin-top: 18rpx; }
.version-box, .version-updates { padding: 18rpx; border-radius: 22rpx; background: #fffaf1; border: 1rpx solid rgba(223, 214, 197, 0.88); }
.version-label { display: block; color: #637169; font-size: 22rpx; line-height: 1.4; }
.version-value { display: block; margin-top: 8rpx; color: #24302c; font-size: 28rpx; font-weight: 800; line-height: 1.3; }
.version-updates { margin-top: 16rpx; }
.version-update { margin-top: 12rpx; color: #4c5a53; font-size: 24rpx; line-height: 1.6; }
.version-form { display: grid; gap: 18rpx; margin-top: 18rpx; }
.version-field { display: block; }
.version-input { margin-top: 12rpx; }
.version-textarea { min-height: 180rpx; margin-top: 12rpx; resize: vertical; }
.version-save { width: 100%; margin-top: 4rpx; }
@media (max-width: 720rpx) {
  .funnel-row, .reply-row, .version-meta { grid-template-columns: 1fr; gap: 10rpx; }
  .funnel-value { text-align: left; }
  .detail-top { flex-direction: column; align-items: flex-start; }
}
