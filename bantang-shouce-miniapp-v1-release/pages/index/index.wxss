.page--home { padding-bottom: 24rpx; }
.hero, .info-card, .progress-card { padding: 22rpx; margin-top: 24rpx; }
.hero { margin-top: 0; }
.hero-copy { margin-top: 24rpx; }
.hero-kicker { display: block; margin-bottom: 16rpx; color: #8f5147; font-size: 24rpx; font-weight: 700; }
.hero-title { display: block; font-size: 48rpx; font-weight: 800; line-height: 1.12; }
.hero-lead { display: block; margin-top: 18rpx; color: #4c5a53; font-size: 24rpx; line-height: 1.72; }
.stage-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16rpx; margin-top: 18rpx; }
.stage-card { display: grid; grid-template-rows: auto auto auto; align-content: center; row-gap: 20rpx; min-height: 188rpx; padding: 20rpx 14rpx; border-radius: 24rpx; background: #fffaf1; border: 1rpx solid rgba(223, 214, 197, 0.88); }
.stage-name { display: block; color: #415f4b; font-size: 26rpx; font-weight: 800; }
.stage-title { display: block; color: #415f4b; font-size: 21rpx; font-weight: 800; line-height: 1.22; white-space: nowrap; }
.stage-count { display: block; color: #637169; font-size: 18rpx; line-height: 1.2; white-space: nowrap; }
.stage-rate { display: block; color: #c97766; font-size: 18rpx; line-height: 1.2; font-weight: 800; white-space: nowrap; }
.stats-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16rpx; margin-top: 20rpx; }
.stats-grid .stat { min-height: 138rpx; }
.stats-grid .stat-label { font-size: 20rpx; line-height: 1.35; }
.progress-bar { overflow: hidden; height: 18rpx; margin-top: 20rpx; border-radius: 999rpx; background: #e8dfcf; }
.progress-bar__inner { height: 100%; border-radius: inherit; background: linear-gradient(90deg, #78927d, #7bbec1, #f3d36b); }
.progress-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 16rpx; }
.progress-rate { color: #c97766; font-size: 30rpx; font-weight: 800; }
@media (max-width: 720rpx) { .stage-grid, .stats-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
