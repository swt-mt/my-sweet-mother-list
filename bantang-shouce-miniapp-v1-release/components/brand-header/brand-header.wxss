.brand-header { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; }
.brand-header.is-compact { gap: 16rpx; }
.brand-left { display: flex; align-items: center; gap: 20rpx; min-width: 0; flex: 1 1 auto; }
.brand-mark { position: relative; width: 132rpx; height: 132rpx; flex: 0 0 auto; filter: drop-shadow(0 16rpx 28rpx rgba(65, 95, 75, 0.18)); }
.brand-header.is-compact .brand-mark { width: 108rpx; height: 108rpx; }
.mark-circle, .mark-wave, .mark-stem, .mark-leaf { position: absolute; }
.mark-circle { inset: 0; border-radius: 50%; background: linear-gradient(135deg, #fffaf2 0%, #f4cdb6 55%, #a7c8bb 100%); }
.mark-wave { left: 14%; width: 72%; height: 20%; border-radius: 999rpx; background: linear-gradient(90deg, rgba(234, 163, 143, 0.95), rgba(93, 143, 119, 0.95)); }
.mark-wave-a { top: 38%; transform: rotate(-12deg); }
.mark-wave-b { top: 56%; left: 20%; width: 62%; transform: rotate(10deg); }
.mark-stem { left: 48%; top: 24%; width: 6%; height: 52%; border-radius: 999rpx; background: #fffdf8; }
.mark-leaf { width: 22%; height: 16%; border-radius: 999rpx 999rpx 999rpx 0; }
.mark-leaf-a { left: 32%; top: 20%; transform: rotate(-42deg); background: #e1a091; }
.mark-leaf-b { left: 52%; top: 20%; transform: rotate(42deg); background: #d9cf8e; }
.brand-copy { min-width: 0; }
.brand-name { display: block; color: #24302c; font-size: 48rpx; font-weight: 800; line-height: 1; letter-spacing: 0; }
.brand-header.is-compact .brand-name { font-size: 42rpx; }
.brand-tagline { display: block; margin-top: 10rpx; color: #415f4b; font-size: 24rpx; font-weight: 700; line-height: 1.45; }
.brand-header.is-compact .brand-tagline { font-size: 22rpx; }
.auth-panel { flex: 0 0 auto; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10rpx; min-width: 130rpx; max-width: 156rpx; }
.auth-avatar { width: 104rpx; height: 104rpx; border-radius: 32rpx; display: flex; align-items: center; justify-content: center; overflow: hidden; }
.auth-avatar.is-logged { border: 1rpx solid rgba(223, 214, 197, 0.88); background: rgba(255, 250, 241, 0.96); box-shadow: 0 10rpx 22rpx rgba(48, 62, 55, 0.08); }
.auth-avatar.is-guest { background: #7a8f7c; color: #fffaf1; }
.auth-image { width: 100%; height: 100%; }
.auth-default { position: relative; width: 100%; height: 100%; border-radius: inherit; background: linear-gradient(135deg, #fff7ee 0%, #edf4ea 100%); }
.default-orb { position: absolute; border-radius: 50%; opacity: 0.96; }
.orb-a { width: 42rpx; height: 42rpx; left: 18rpx; top: 18rpx; background: rgba(201, 119, 102, 0.7); }
.orb-b { width: 48rpx; height: 48rpx; right: 18rpx; bottom: 18rpx; background: rgba(120, 146, 125, 0.72); }
.default-bar { position: absolute; left: 50%; top: 14rpx; width: 12rpx; height: 76rpx; margin-left: -6rpx; border-radius: 999rpx; background: #fffaf1; }
.guest-text { color: #fffaf1; font-size: 22rpx; font-weight: 800; line-height: 1.2; text-align: center; padding: 0 12rpx; }
.auth-name { display: block; max-width: 100%; color: #24302c; font-size: 22rpx; font-weight: 800; line-height: 1.25; text-align: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.auth-name--guest { color: #637169; font-weight: 700; }
